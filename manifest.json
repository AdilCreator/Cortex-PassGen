{
  "manifest_version": 3,
  "name": "Cortex PassGen",
  "version": "3.0",
  "description": "Strong password generator created by Adil",
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["clipboardWrite"]
}